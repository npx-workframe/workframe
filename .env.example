# Workframe — Environment Variables
# =============================================================================
# Workframe compose env: infra/compose/workframe/.env
# Dev defaults for running packages outside Docker (apps/web vite dev, etc.)
# =============================================================================

# --- Monorepo substrate (packages/auth, packages/db, packages/env) -------------
MONOREPO_HMAC_KEY=change-me-change-me-change-me-change-me
MONOREPO_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
MONOREPO_SESSION_SECRET=change-me-change-me-change-me-change-me

OTP_TTL_MINUTES=10
SESSION_TTL_DAYS=30
REFRESH_TOKEN_TTL_DAYS=7

# SMTP (optional in dev, required in prod)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# OAuth — GitHub used for Workframe owner/admin onboarding
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_SCOPE=read:user user:email

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_SCOPE=openid email profile

# --- Local dev shortcuts --------------------------------------------------------
# Web app dev server port (apps/web/vite)
VITE_WEB_PORT=5173

# Workframe API port (python server.py outside Docker)
WORKFRAME_API_PORT=19120

# Browser URL for local Workframe UI
APP_BASE_URL=http://127.0.0.1:18644
