{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workfra.me/schemas/ledger-backlog.schema.json",
  "title": "WorkframeLedgerBacklog",
  "description": "Single source of truth for audit synthesis, north-star phases, and agent loop handoff.",
  "type": "object",
  "required": ["schema_version", "updated", "items"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "updated": { "type": "string", "format": "date" },
    "north_star_ref": { "type": "string" },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/item" }
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "required": ["id", "title", "wave", "priority", "status", "sources"],
      "properties": {
        "id": { "type": "string", "pattern": "^WF-[A-Z0-9-]+$" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "wave": {
          "type": "string",
          "enum": [
            "release-truth",
            "authority",
            "broker",
            "run-ledger",
            "adapter",
            "cell",
            "marketplace",
            "meta"
          ]
        },
        "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
        "status": {
          "type": "string",
          "enum": [
            "todo",
            "in_progress",
            "review",
            "done",
            "partial",
            "blocked",
            "deferred"
          ]
        },
        "sources": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Audit IDs, north-star phase refs, or doc paths"
        },
        "acceptance": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commits, harness scenario IDs, or evidence JSON paths"
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blocks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "owner_role": {
          "type": "string",
          "enum": ["implementer", "reviewer", "harness", "docs", "design"]
        },
        "workflow": {
          "type": "object",
          "properties": {
            "assignee": { "type": ["string", "null"] },
            "reviewer": { "type": ["string", "null"] },
            "claimed_at": { "type": ["string", "null"] },
            "completed_at": { "type": ["string", "null"] },
            "patch_refs": {
              "type": "array",
              "items": { "type": "string" }
            },
            "notes": { "type": "string" }
          }
        },
        "spec": {
          "type": "object",
          "description": "Optional spec-kit artifact paths under docs/ledger/specs/",
          "properties": {
            "constitution": { "type": "string" },
            "spec": { "type": "string" },
            "plan": { "type": "string" },
            "tasks": { "type": "string" }
          }
        }
      }
    }
  }
}
