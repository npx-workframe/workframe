{
  "name": "@workframe/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "description": "Workframe Desktop — thin Electron shell for Workframe",
  "author": "Workframe",
  "scripts": {
    "dev": "node scripts/build.mjs && electron .",
    "watch": "tsc -p tsconfig.json --watch",
    "dev:electron": "electron .",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'no desktop tests yet'",
    "package:win": "electron-builder --win --x64 --arm64",
    "package:mac": "electron-builder --mac --x64 --arm64",
    "package:linux": "electron-builder --linux --x64 --arm64",
    "package:all": "electron-builder -mwl"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "koffi": "^2.12.2"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "@types/node": "^24.12.4",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.workframe.desktop",
    "productName": "Workframe",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Development"
    }
  }
}
