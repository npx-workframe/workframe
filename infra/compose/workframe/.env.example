# Workframe compose — copy to .env and edit before deploy.
# Slot N → ports N*10000+{8642 gateway, 9119 dashboard, 9120 api, 8644 ui}.

WORKFRAME_INSTALL_ID=wf_local_slot1
WORKFRAME_SLOT=1
WORKFRAME_PROJECT=Workframe
WORKFRAME_NATIVE_PROFILE=workframe-agent

WORKFRAME_GATEWAY_PORT=18642
WORKFRAME_DASHBOARD_PORT=19119
WORKFRAME_API_PORT=19120
WORKFRAME_SUPERVISOR_PORT=18090
WORKFRAME_UI_PORT=18644

# Host paths (VPS deploy) — used by publish wizard for setup commands.
WORKFRAME_HOST_PROJECT_ROOT=/opt/workframe/repo
WORKFRAME_HOST_COMPOSE_DIR=/opt/workframe/repo/infra/compose/workframe

# Static SPA mount for workframe-ui nginx (relative to this compose dir).
WORKFRAME_UI_STATIC_DIR=../../../apps/web/dist

# Security: default to supervisor-backed secure mode, even for local Docker.
# Use docker-compose.dev-authority.yml only when you intentionally need API host authority.
SECURE_MODE=true
DEV_LOCAL_UNSAFE=false

# Deployment hardening tier (default trusted_team for local dogfood).
# single_user_local | trusted_team | public_multi_user
WORKFRAME_DEPLOYMENT_MODE=trusted_team

# BFF version stamp (stack updates + /api/health)
WORKFRAME_API_VERSION=0.1.0

# --- public_multi_user production (uncomment and fill; see PUBLIC_DEPLOY.md) ---
# WORKFRAME_DEPLOYMENT_MODE=public_multi_user
# SECURE_MODE=true
# DEV_LOCAL_UNSAFE=false
# APP_BASE_URL=https://your.public.host
# CORS_ALLOW_ORIGIN=https://your.public.host
# ALLOWED_HOSTS=your.public.host

# Required when SECURE_MODE=true (generate before production deploy).
ZK_AUTH_HMAC_KEY=
ZK_AUTH_ENCRYPTION_KEY=
ZK_AUTH_SESSION_SECRET=
WORKFRAME_API_TOKEN=

# Credential vault master key (32 bytes base64). Required for public_multi_user.
# Local dogfood: omit to auto-generate runtime/workframe-api-data/.vault_kek on first boot.
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
WORKFRAME_VAULT_KEK=

# Internal LLM/action proxy shared secret. Required for public_multi_user.
# Local dogfood: omit to auto-generate runtime/workframe-api-data/.proxy_token on first API boot.
# Gateway reads the same file via compose mount (or set WORKFRAME_PROXY_TOKEN here).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
WORKFRAME_PROXY_TOKEN=

# Profile lifecycle in SECURE_MODE uses workframe-supervisor (generate: scripts/workframe/setup-supervisor.sh).
WORKFRAME_SUPERVISOR_TOKEN=

# SMTP — required for real verification/invite email when DEV_LOCAL_UNSAFE=false.
# Leave SMTP_HOST empty in local dev; API returns a dev OTP on the sign-in screen instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
APP_BASE_URL=http://127.0.0.1:18644
# Hermes dashboard public link follows APP_BASE_URL in docker-compose.yml (${APP_BASE_URL}/hermes-dashboard).

# Optional: public hostname for auto HTTPS during vps-deploy (or derived from APP_BASE_URL when not loopback).
# WORKFRAME_PUBLIC_HOST=your.public.host
# After DNS: node scripts/workframe/set-compose-public-url.mjs https://your.public.host
# Or VPS deploy: scripts/workframe/vps-pull-deploy.ps1 -PublicHost your.public.host

# Local dogfood: set to 1 only with docker-compose.dev-authority.yml.
WORKFRAME_ENABLE_ADMIN_UPDATES=0

# Optional: block direct provider API egress from gateway (see docker-compose.egress-broker.yml).
# WORKFRAME_FORCE_AGENT_EGRESS_BROKER=true

# Optional: stack-wide GitHub OAuth app (workspace Integrations tab can override per workframe).
WORKFRAME_GITHUB_OAUTH_CLIENT_ID=
WORKFRAME_GITHUB_OAUTH_CLIENT_SECRET=
